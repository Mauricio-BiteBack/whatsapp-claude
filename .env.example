# AgentKit — Umgebungsvariablen
# Kopiere diese Datei als .env und fülle deine Daten ein:
#   cp .env.example .env
#
# Claude Code hilft dir, diese Werte während des Setups auszufüllen.
# Lade die .env-Datei NIEMALS auf GitHub hoch.

# ── Anthropic API ──────────────────────────────────────────
# Erhalten unter: https://platform.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# ── WhatsApp-Anbieter ──────────────────────────────────────
# Optionen: whapi | meta | twilio
WHATSAPP_PROVIDER=whapi

# ── Whapi.cloud (falls WHATSAPP_PROVIDER=whapi) ───────────
# Erhalten unter: https://whapi.cloud (kostenloser Plan verfügbar)
WHAPI_TOKEN=

# ── Meta Cloud API (falls WHATSAPP_PROVIDER=meta) ─────────
# Einrichten unter: https://developers.facebook.com
# META_ACCESS_TOKEN=
# META_PHONE_NUMBER_ID=
# META_VERIFY_TOKEN=agentkit-verify

# ── Twilio (falls WHATSAPP_PROVIDER=twilio) ───────────────
# Einrichten unter: https://twilio.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ── Server ────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development

# ── Datenbank ─────────────────────────────────────────────
# Lokal (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./agentkit.db
# Produktion (PostgreSQL auf Railway):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
